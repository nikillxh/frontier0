# ------------------------------------------------------------------
# FRONTIER0 environment
# Copy to .env and fill in. Localhost works with the defaults below.
# ------------------------------------------------------------------

# "local" uses anvil + mock 0G adapters. "testnet" uses 0G Galileo + real 0G services.
FRONTIER_ENV=local

# ---- Chain ----
# Local (anvil) defaults:
LOCAL_RPC_URL=http://127.0.0.1:8545
# Anvil's first well-known dev account (DO NOT use on a real network):
LOCAL_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# 0G Galileo testnet:
TESTNET_RPC_URL=https://evmrpc-testnet.0g.ai
TESTNET_CHAIN_ID=16602
# Your funded testnet key (fund via https://faucet.0g.ai). NEVER commit a real key.
TESTNET_PRIVATE_KEY=

# ---- 0G Storage (testnet) ----
ZG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# ---- 0G Compute (testnet, Router path) ----
# Get an API key from https://pc.0g.ai (Router) or the compute marketplace.
ZG_COMPUTE_BASE_URL=
ZG_COMPUTE_API_KEY=
ZG_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct
# Ask the Router to attest responses came from a real TEE provider:
ZG_COMPUTE_VERIFY_TEE=true

# ---- Web ----
NEXT_PUBLIC_FRONTIER_ENV=local
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
NEXT_PUBLIC_WALLETCONNECT_ID=
