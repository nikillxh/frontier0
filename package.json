{
  "name": "frontier0",
  "version": "0.1.0",
  "private": true,
  "description": "FRONTIER0 - decentralized market for humanity's hardest problems, built on 0G",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build && pnpm --filter web build",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "contracts:build": "pnpm --filter @frontier0/contracts build",
    "contracts:test": "pnpm --filter @frontier0/contracts test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0"
  }
}
